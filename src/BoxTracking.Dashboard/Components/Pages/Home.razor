@page "/"
@using Microsoft.AspNetCore.SignalR.Client
@using BoxTracking.Shared.Events
@using BoxTracking.Shared.Models
@implements IAsyncDisposable
@inject NavigationManager NavigationManager

<PageTitle>Box Tracking Dashboard</PageTitle>

<div class="container mt-4">
    <h1>📦 Box Tracking Dashboard</h1>
    <p class="text-muted">Real-time worker tracking system</p>

    @if (!isConnected)
    {
        <div class="alert alert-warning" role="alert">
            ⚠️ Connecting to real-time updates...
        </div>
    }
    else
    {
        <div class="alert alert-success" role="alert">
            ✅ Connected - Showing real-time events
        </div>
    }

    <div class="row mt-4">
        <div class="col-md-3">
            <div class="card text-white bg-success mb-3">
                <div class="card-header">Boxes Cleaned</div>
                <div class="card-body">
                    <h2 class="card-title">@metrics.BoxesCleaned</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-warning mb-3">
                <div class="card-header">Boxes Repaired</div>
                <div class="card-body">
                    <h2 class="card-title">@metrics.BoxesRepaired</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-primary mb-3">
                <div class="card-header">Boxes Loaded</div>
                <div class="card-body">
                    <h2 class="card-title">@metrics.BoxesLoaded</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-info mb-3">
                <div class="card-header">In Progress</div>
                <div class="card-body">
                    <h2 class="card-title">@metrics.BoxesInProgress</h2>
                </div>
            </div>
        </div>
    </div>

    @if (metrics.LoadingAttemptsFailed > 0)
    {
        <div class="alert alert-danger" role="alert">
            ⚠️ <strong>@metrics.LoadingAttemptsFailed</strong> loading attempts failed (uncleaned boxes blocked)
        </div>
    }

    <div class="card mt-4">
        <div class="card-header">
            <h5>Recent Events</h5>
        </div>
        <div class="card-body">
            @if (recentEvents.Count == 0)
            {
                <p class="text-muted">No events yet. Use the Simulator to send events!</p>
            }
            else
            {
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Box ID</th>
                            <th>Event</th>
                            <th>Worker</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var evt in recentEvents)
                        {
                            <tr>
                                <td>@evt.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                                <td><code>@evt.BoxId</code></td>
                                <td>@GetEventBadge(evt.EventType)</td>
                                <td>@evt.WorkerId</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <div class="mt-4">
        <p class="text-muted">
            <small>
                Last updated: @metrics.LastUpdated.ToLocalTime().ToString("HH:mm:ss")
            </small>
            <br />
            <small>
                Connection status: 
                @if (isConnected)
                {
                    <span class="text-success">● Connected</span>
                }
                else
                {
                    <span class="text-danger">● Disconnected</span>
                }
            </small>
        </p>
    </div>
</div>

@code {
    private HubConnection? hubConnection;
    private DailyMetrics metrics = new();
    private List<RecentEvent> recentEvents = new();
    private bool isConnected = false;

    protected override async Task OnInitializedAsync()
    {
        // Connect to SignalR hub
        hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/dashboard"))
            .WithAutomaticReconnect()
            .Build();

        // Handle reconnection
        hubConnection.Reconnecting += error =>
        {
            isConnected = false;
            StateHasChanged();
            return Task.CompletedTask;
        };

        hubConnection.Reconnected += connectionId =>
        {
            isConnected = true;
            StateHasChanged();
            return Task.CompletedTask;
        };

        hubConnection.Closed += error =>
        {
            isConnected = false;
            StateHasChanged();
            return Task.CompletedTask;
        };

        // Listen for events from EventProcessor
        hubConnection.On<BoxEvent, DailyMetrics>("ReceiveEvent", (evt, updatedMetrics) =>
        {
            metrics = updatedMetrics;
            
            // Add event to recent list
            recentEvents.Insert(0, new RecentEvent
            {
                EventId = evt.EventId,
                BoxId = evt.BoxId,
                EventType = evt.EventType,
                WorkerId = evt.WorkerId,
                Timestamp = evt.Timestamp
            });

            // Keep only last 20 events
            if (recentEvents.Count > 20)
                recentEvents.RemoveAt(recentEvents.Count - 1);

            InvokeAsync(StateHasChanged);
        });

        // Listen for metrics updates
        hubConnection.On<DailyMetrics>("ReceiveMetrics", (updatedMetrics) =>
        {
            metrics = updatedMetrics;
            InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
        isConnected = true;
    }

    private MarkupString GetEventBadge(string eventType)
    {
        var (badgeClass, text) = eventType switch
        {
            nameof(BoxCleaningStarted) => ("bg-info", "Cleaning Started"),
            nameof(BoxCleaningCompleted) => ("bg-success", "Cleaning Completed"),
            nameof(BoxRepairStarted) => ("bg-warning", "Repair Started"),
            nameof(BoxRepairCompleted) => ("bg-success", "Repair Completed"),
            nameof(BoxLoadingAttempted) => ("bg-primary", "Loading Attempted"),
            _ => ("bg-secondary", eventType)
        };

        return new MarkupString($"<span class=\"badge {badgeClass}\">{text}</span>");
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}
